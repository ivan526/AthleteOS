import { PrismaClient } from '@prisma/client';

const prisma = new PrismaClient();

async function main() {
  // 创建测试用户
  const user = await prisma.user.upsert({
    where: { id: 'b23d32aa-870a-449e-8572-b1fccd8c00e0' },
    update: {},
    create: {
      id: 'b23d32aa-870a-449e-8572-b1fccd8c00e0',
      email: 'test@example.com',
      name: '测试用户',
      createdAt: new Date(),
      updatedAt: new Date(),
    },
  });

  console.log('测试用户创建成功:', user.id);

  // 创建运动员档案
  const profile = await prisma.athleteProfile.upsert({
    where: { userId: user.id },
    update: {},
    create: {
      userId: user.id,
      primarySport: 'running',
      weeklyAvailableDays: 5,
      preferredSports: JSON.stringify(['running', 'cycling']),
      createdAt: new Date(),
      updatedAt: new Date(),
    },
  });

  console.log('运动员档案创建成功');

  // 创建测试Intervals连接账户
  const connectedAccount = await prisma.connectedAccount.upsert({
    where: {
      userId_provider: {
        userId: user.id,
        provider: 'intervals.icu',
      },
    },
    update: {},
    create: {
      userId: user.id,
      provider: 'intervals.icu',
      athleteId: 'i212288',
      apiKey: 'test-api-key',
      syncStatus: 'success',
      syncMessage: '同步完成：新增 56 条训练记录',
      lastSyncAt: new Date(),
      createdAt: new Date(),
      updatedAt: new Date(),
    },
  });

  console.log('Intervals连接账户创建成功');

  // 生成过去90天的模拟训练数据
  const activities = [];
  const today = new Date();

  for (let i = 90; i >= 0; i--) {
    const date = new Date(today);
    date.setDate(date.getDate() - i);

    // 每周休息1-2天
    if (Math.random() > 0.8) continue;

    // 随机生成训练类型
    const types = ['easy_run', 'tempo_run', 'interval_run', 'long_run', 'cycling', 'strength'];
    const type = types[Math.floor(Math.random() * types.length)];

    let durationMinutes: number;
    let tss: number;
    let sport: string;
    let distanceMeters: number;

    switch (type) {
      case 'easy_run':
        durationMinutes = Math.floor(Math.random() * 20) + 30; // 30-50分钟
        tss = durationMinutes * 0.6 + Math.floor(Math.random() * 10);
        sport = 'running';
        distanceMeters = Math.floor(durationMinutes * 150); // 配速6:40左右
        break;
      case 'tempo_run':
        durationMinutes = Math.floor(Math.random() * 20) + 40; // 40-60分钟
        tss = durationMinutes * 1.0 + Math.floor(Math.random() * 15);
        sport = 'running';
        distanceMeters = Math.floor(durationMinutes * 170); // 配速5:50左右
        break;
      case 'interval_run':
        durationMinutes = Math.floor(Math.random() * 20) + 50; // 50-70分钟
        tss = durationMinutes * 1.3 + Math.floor(Math.random() * 20);
        sport = 'running';
        distanceMeters = Math.floor(durationMinutes * 180); // 配速5:30左右
        break;
      case 'long_run':
        durationMinutes = Math.floor(Math.random() * 60) + 60; // 60-120分钟
        tss = durationMinutes * 0.8 + Math.floor(Math.random() * 20);
        sport = 'running';
        distanceMeters = Math.floor(durationMinutes * 160); // 配速6:15左右
        break;
      case 'cycling':
        durationMinutes = Math.floor(Math.random() * 60) + 45; // 45-105分钟
        tss = durationMinutes * 0.7 + Math.floor(Math.random() * 15);
        sport = 'cycling';
        distanceMeters = Math.floor(durationMinutes * 400); // 24公里/小时
        break;
      case 'strength':
        durationMinutes = Math.floor(Math.random() * 30) + 30; // 30-60分钟
        tss = durationMinutes * 0.8 + Math.floor(Math.random() * 10);
        sport = 'strength';
        distanceMeters = 0;
        break;
      default:
        continue;
    }

    // 随机添加一些波动，模拟真实训练负荷变化
    if (i < 30) {
      // 最近30天训练量增加10%
      tss = tss * 1.1;
    } else if (i < 60) {
      // 中间30天正常
      tss = tss * 1.0;
    } else {
      // 前30天减少10%
      tss = tss * 0.9;
    }

    // 确保TSS是正数
    tss = Math.max(20, Math.round(tss));

    activities.push({
      connectedAccountId: connectedAccount.id,
      providerActivityId: `activity_${i}_${date.getTime()}`,
      sport,
      startTime: new Date(date.setHours(Math.floor(Math.random() * 8) + 6, 0, 0, 0)), // 早上6-14点
      durationSeconds: durationMinutes * 60,
      distanceMeters: distanceMeters > 0 ? distanceMeters : null,
      tss,
      intensityFactor: tss / durationMinutes,
      avgHr: Math.floor(Math.random() * 40) + 110, // 110-150
      maxHr: Math.floor(Math.random() * 30) + 150, // 150-180
      avgPower: sport === 'cycling' ? Math.floor(Math.random() * 100) + 150 : null,
      normalizedPower: sport === 'cycling' ? Math.floor(Math.random() * 100) + 170 : null,
      avgPace: sport === 'running' ? (durationMinutes * 60) / (distanceMeters / 1000) : null, // 秒/公里
      elevationGain: Math.random() > 0.5 ? Math.floor(Math.random() * 200) : 0,
      createdAt: new Date(),
      updatedAt: new Date(),
    } as any);
  }

  // 批量插入训练数据
  await prisma.activity.createMany({
    data: activities,
    skipDuplicates: true,
  });

  console.log(`生成并插入了 ${activities.length} 条模拟训练记录`);
}

main()
  .catch((e) => {
    console.error(e);
    process.exit(1);
  })
  .finally(async () => {
    await prisma.$disconnect();
  });
