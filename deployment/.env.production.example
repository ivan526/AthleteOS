DOMAIN=athlete.example.com
CORS_ORIGINS=https://athlete.example.com

# Generate independently:
#   openssl rand -hex 32
JWT_SECRET=replace-with-at-least-32-random-characters

# Generate:
#   openssl rand -hex 32
CREDENTIAL_ENCRYPTION_KEY=replace-with-64-character-hex-key

ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
ALLOW_REGISTRATION=true

# Keep true for HTTPS. Set false only for a temporary IP-address HTTP deployment.
COOKIE_SECURE=true

# Optional: bind registration to an existing local user and its training data.
# Query locally:
#   sqlite3 backend/prisma/dev.db 'select id,email,name from User;'
LEGACY_USER_ID=
LEGACY_USER_EMAIL=
